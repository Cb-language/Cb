<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:composer.ViewModels"
        xmlns:views="clr-namespace:composer.Views"
        x:Class="composer.Views.MainView"
        x:DataType="vm:MainViewModel"
        Title="Composer"
        Width="1024" Height="600"
        FontFamily="{DynamicResource PrimaryFontFamily}"
        >
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveSourceCommand}" />
    
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding NextTabCommand}" />
    
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseCurrentTabCommand}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding AddNewTabCommand}" />
    
        <KeyBinding Gesture="Ctrl+T" Command="{Binding TranslateCommand}" />
        <KeyBinding Gesture="Ctrl+E" Command="{Binding CompileCommand}" />
        <KeyBinding Gesture="Ctrl+R" Command="{Binding RunCommand}" />
        
        <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Gesture="Ctrl+Add" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Gesture="Ctrl+Subtract" Command="{Binding ZoomOutCommand}"/>

    </Window.KeyBindings>
    
    <Design.DataContext><vm:MainViewModel/></Design.DataContext>

    <Grid Background="{DynamicResource PrimaryBackground}" ColumnDefinitions="Auto, *">
        <Border Grid.Column="0" Padding="10" Background="{DynamicResource PrimaryBackgroundGradientBrush}" 
                Width="{Binding BorderWidth}">
            <Grid RowDefinitions="*, Auto">
                
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="15">
                        <Image PointerPressed="InputElement_OnPointerPressed__SvgImage__Assets_Images_logo_svg_" 
                               Source="{SvgImage /Assets/Images/logo.svg}" Width="200" IsVisible="{Binding Expanded}"/>
                        <Image PointerPressed="InputElement_OnPointerPressed__SvgImage__Assets_Images_logo_svg_" 
                               Source="{SvgImage /Assets/Images/logo.svg}" Width="50" IsVisible="{Binding !Expanded}"/>

                        <TextBlock Text="File Operations" HorizontalAlignment="Center" FontFamily="{DynamicResource PrimaryFontFamily}" IsVisible="{Binding Expanded}" Foreground="{DynamicResource PrimaryForeground}"/>

                        <Button HorizontalAlignment="Stretch" Command="{Binding OpenFolderCommand}">
                            <StackPanel Orientation="Horizontal">
                                 <Label Content="📁" Padding="0 2 0 0"/>
                                 <Label Content="Open Folder" IsVisible="{Binding Expanded}"/>
                            </StackPanel>
                        </Button>
                        
                        <Button HorizontalAlignment="Stretch" Command="{Binding OpenSourceFileCommand}">
                            <StackPanel Orientation="Horizontal">
                                 <Label Content="📂" Padding="0 2 0 0"/>
                                 <Label Content="Open File" IsVisible="{Binding Expanded}"/>
                            </StackPanel>
                        </Button>
                     
                        <Button HorizontalAlignment="Stretch" Command="{Binding ChangeDestPathCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Label Content="📤" Padding="0 2 0 0"/>
                               <Label Content="Destination" IsVisible="{Binding Expanded}"/>
                            </StackPanel>
                        </Button>

                        <Separator IsVisible="{Binding Expanded}" Margin="0,10" Opacity="0.5"/>
                     
                        <TextBlock Text="Actions" HorizontalAlignment="Center" FontFamily="{DynamicResource PrimaryFontFamily}" IsVisible="{Binding Expanded}" Foreground="{DynamicResource PrimaryForeground}"/>

                        <Button HorizontalAlignment="Stretch" Command="{Binding SaveSourceCommand}">
                            <StackPanel Orientation="Horizontal">
                                 <Label Content="💾" Padding="0 4 0 0"/>
                                <Label Content="Save" IsVisible="{Binding Expanded}"/>
                            </StackPanel>
                        </Button>

                         <Button HorizontalAlignment="Stretch" Command="{Binding TranslateCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Label Content="🔄" Padding="0 4 0 0"/>
                               <Label Content="Translate" IsVisible="{Binding Expanded}"/>
                            </StackPanel>
                        </Button>

                        <Button HorizontalAlignment="Stretch" Command="{Binding CompileCommand}">
                            <StackPanel Orientation="Horizontal">
                                 <Label Content="🛠️" Padding="0 4 0 0"/>
                                <Label Content="Compile" IsVisible="{Binding Expanded}"/>
                            </StackPanel>
                         </Button>

                        <Button HorizontalAlignment="Stretch" Command="{Binding RunCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Label Content="▶️" Padding="0 0 0 5"/>
                               <Label Content="Run" Padding="5 4 0 0" IsVisible="{Binding Expanded}"/>
                            </StackPanel>
                        </Button>
                        
                        <Separator IsVisible="{Binding Expanded}" Margin="0,10" Opacity="0.5"/>
                        <TextBlock Text="Project Files" HorizontalAlignment="Center" FontFamily="{DynamicResource PrimaryFontFamily}" IsVisible="{Binding Expanded}" Foreground="{DynamicResource PrimaryForeground}"/>
                        
                        <ItemsControl ItemsSource="{Binding FolderFiles}" IsVisible="{Binding Expanded}">
                             <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- ReSharper disable once Xaml.PossibleNullReferenceException -->
                                    <Button Content="{Binding}" 
                                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).OpenFileFromListCommand}" 
                                            CommandParameter="{Binding}"
                                            HorizontalAlignment="Stretch"
                                            Background="Transparent"
                                            BorderThickness="0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
                
                <StackPanel Grid.Row="1" VerticalAlignment="Bottom" IsVisible="{Binding Expanded}" Margin="0,10,0,0">
                    <TextBlock Text="Current Output Path:" FontSize="10" Foreground="#AAAAAA"/>
                    <!-- ReSharper disable once Xaml.PossibleNullReferenceException -->
                    <TextBlock Text="{Binding SelectedTab.OutFilePath}" TextWrapping="Wrap" FontSize="10" Foreground="#AAAAAA" Margin="0,2"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="5"/>    <RowDefinition Height="150"/>  </Grid.RowDefinitions>
            
            <TabControl x:Name="TabControl" Grid.Row="0" Grid.RowSpan="2" ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedTab}">
                <TabControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:FileTabViewModel"> 
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock FontSize="14" Text="{Binding Header}" VerticalAlignment="Center"/>
                            <Button Command="{Binding CloseTabCommand}" Content="×" Padding="5,0" Background="Transparent" BorderThickness="0"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:FileTabViewModel">
                        <views:CodeEditor CodeContent="{Binding Content, Mode=TwoWay}" 
                                          DiagnosticsJson="{Binding DiagnosticsJson}" />
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,5,0" Spacing="10">
                 <Button Command="{Binding AddNewTabCommand}" Content="+" FontWeight="Bold" Background="Transparent" BorderBrush="#444444" BorderThickness="1"/>
                 <Rectangle Width="1" Height="20" Fill="#444444" Margin="5,0"/>
                 <StackPanel Orientation="Horizontal" Background="#22000000">
                    <TextBlock Text="{Binding TranspilerExePath}" Margin="10 0 0 0" VerticalAlignment="Center" Foreground="Gray" FontSize="10" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                    <ToggleButton IsChecked="{Binding ShouldLspRun}" Background="Transparent" BorderThickness="0" ToolTip.Tip="Toggle LSP">
                        <Label Content="📡" Padding="0"/>
                    </ToggleButton>
                    <Button Command="{Binding SelectTranspilerCommand}" Background="Transparent" BorderThickness="0" ToolTip.Tip="Set Transpiler">
                        <StackPanel Orientation="Horizontal">
                                <Label Content="⚙️" Padding="0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <GridSplitter Grid.Row="2" Background="#333333" ResizeDirection="Rows" HorizontalAlignment="Stretch"/>

            <Grid Grid.Row="3" RowDefinitions="Auto, *">
                <Border Grid.Row="0" Background="#252526" Padding="10,2">
                    <Grid>
                        <TextBlock Text="TERMINAL" 
                                   FontSize="10" 
                                   FontWeight="Bold" 
                                   Foreground="#888888" 
                                   VerticalAlignment="Center"/>
                   
                        <Button Content="Clear" 
                                Command="{Binding ClearTerminalOutputCommand}" 
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Center"
                                FontSize="10"
                                Padding="5,2"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#AAAAAA"/>
                    </Grid>
                </Border>
                
                <Border Grid.Row="1"
                        Background="#1E1E1E"
                        BorderThickness="0">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">

                        <ItemsControl ItemsSource="{Binding Terminal.Spans}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontFamily="Consolas, Menlo, Monospace"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Text="{Binding Text}"
                                               Foreground="{Binding Foreground}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </ScrollViewer>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>