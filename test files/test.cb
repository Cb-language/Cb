song prelude() -> degree
‚àÆ
    f()‚ïë
    playBar("k:",k())‚ïë
    p("p()")‚ïë

    bar b1 = "add(3,2) + k() = " + (add(3,2) + k())‚ïë
    p(b1)‚ïë
    getAndPrint()‚ïë

    D | cres |
    ‚àÆ
        playBar("entered if")‚ïë
    ‚òâ
    B\1‚ïë
‚òâ

song k() -> note
‚àÆ
    B\'s'‚ïë
‚òâ

song ¬©(p) f()
‚àÆ
    p("Hello World!")‚ïë
    B‚ïë
‚òâ

song p(bar b)
‚àÆ
    playBar(b)‚ïë
‚òâ

song add(degree x, degree y) -> degree
‚àÆ
    B\x+y‚ïë
‚òâ

song recursion(degree x)
‚àÆ
    recursion(x-1)‚ïë
‚òâ

song ¬©(p) getAndPrint()
‚àÆ
    playBar("Enter a bar")‚ïë
    bar b‚ïë
    hear(b)‚ïë
    p(b)‚ïë
‚òâ
