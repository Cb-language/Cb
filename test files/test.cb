song prelude() -> degree
‚àÆ
    f()‚ïë
    playBar("k:",k())‚ïë
    p("p()")‚ïë

    bar b1 = "add(3,2) + k() = " + (add(3,2) + k())‚ïë
    p(b1)‚ïë
    B\0‚ïë
‚òâ

song k() -> note
‚àÆ
    B\'s'‚ïë
‚òâ

song f()
‚àÆ
    playBar("Hello World!")‚ïë
    B‚ïë
‚òâ

song p(bar b)
‚àÆ
    playBar(b)‚ïë
‚òâ

song add(degree x, degree y) -> degree
‚àÆ
    B\x+y‚ïë
‚òâ
