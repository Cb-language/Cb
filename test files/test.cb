song prelude() -> degree
‚àÆ
    test1()‚ïë

    test2(2, 1)‚ïë

    B\0‚ïë
‚òâ

song test1()
‚àÆ
    degree size = 10‚ïë
    riff riff degree x[size][size]‚ïë
    degree i‚ïë
    degree j‚ïë

    G ‚ïë: i < size :‚ïë
    ‚àÆ
        j = 0‚ïë
        G ‚ïë: j < size :‚ïë
        ‚àÆ
            x[i][j] = 10*i+j‚ïë
            j‚ôØ‚ïë
        ‚òâ
        i‚ôØ‚ïë
    ‚òâ

    playBar("x: ", x)‚ïë
    playBar("x[1::2][1::2]: ", x[1::2][1::2])‚ïë ?? x[1::2] is x[1], x[3], x[5], x[7], x[9]. then [x[1], x[3], x[5], x[7], x[9]][1::2] is x[3], x[7]
    playBar(-1)‚ïë ?? -1
    playBar(+2)‚ïë ?? 2
    playBar(*3)‚ïë ?? 3
    playBar(-(3+/4))‚ïë ?? -3
    playBar(//5)‚ïë ?? 0.2
‚òâ

song test2(degree size, degree val)
‚àÆ
    riff degree w[size] = val‚ïë
    size‚ôØ‚ïë
    riff riff degree x[size][] = w‚ïë
    size‚ôØ‚ïë
    riff riff riff degree y[size][][] = x‚ïë
    size‚ôØ‚ïë
    riff riff riff riff degree z[size][][][] = y‚ïë

    playBar("z: ", z)‚ïë
‚òâ