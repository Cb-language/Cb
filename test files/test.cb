song prelude() -> degree
‚àÆ
    playBar("Enter a positive whole number, 0 to exit")‚ïë
    playBar()‚ïë

    G‚ïë:cres:‚ïë
    ‚àÆ
        sharp degree x‚ïë
        play("Enter x:")‚ïë
        hear(x)‚ïë
        playBar()‚ïë

        D |x == 0|
        ‚àÆ
            pause‚ïë
        ‚òâ

        playBar("DecToBin(BinToDec(x)) ?= x:", BinToDec(DecToBin(x)) == x)‚ïë
    ‚òâ

    B\0‚ïë
‚òâ

song BinToDec(sharp degree b) -> sharp degree
‚àÆ
    sharp degree x‚ïë
    G ‚ïë:b > 0:‚ïë
    ‚àÆ
        x += b % 10‚ïë
        x *= 2‚ïë
        b /= 10‚ïë
    ‚òâ

    B\x‚ïë
‚òâ

song DecToBin(sharp degree n) -> sharp degree
‚àÆ
    sharp degree x‚ïë

    G ‚ïë: n > 0 :‚ïë
    ‚àÆ
        x *= 10‚ïë
        x += 1 - n % 2‚ïë
        n /= 2‚ïë
    ‚òâ

    B\x‚ïë
‚òâ